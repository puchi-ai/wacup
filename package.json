{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.cjs",
    "clean:win": "if exist dist rmdir /s /q dist && if exist server.cjs del server.cjs",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.68",
    "@mysten-incubation/memwal": "^0.0.7",
    "@mysten/dapp-kit-react": "^2.1.2",
    "@mysten/sui": "^2.18.0",
    "@tailwindcss/vite": "^4.1.14",
    "@upstash/redis": "^1.38.0",
    "@vitejs/plugin-react": "^5.0.4",
    "ai": "^6.0.204",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@vercel/node": "^5.8.17",
    "esbuild": "^0.28.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^8.0.16"
  }
}
