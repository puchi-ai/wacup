# OPENROUTER_API_KEY: Required for AI chat via OpenRouter (multi-model gateway).
# Get your free API key at: https://openrouter.ai/keys
# OpenRouter gives access to 100+ models including Llama, Mistral, Gemini, DeepSeek, etc.
OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY"

# AI_MODEL: The default model to use for AI chat (OpenRouter model ID).
# Free models (rate-limited):
#   meta-llama/llama-4-scout:free  - Fast, great for chat (default)
#   google/gemini-2.0-flash-001     - Google's fast free model
#   mistralai/mistral-saba-2502:free - Fast, multilingual
# Paid models (set your own API budget):
#   anthropic/claude-sonnet-4-20250514
#   openai/gpt-4o
# See full list: https://openrouter.ai/models
AI_MODEL="meta-llama/llama-4-scout:free"

# APP_URL: The URL where this applet is hosted.
APP_URL="http://localhost:3000"

# ===== WALRUS MEMORY (MemWal SDK - Mainnet) =====
# MemWalAccount object ID on Sui (generate from https://memory.walrus.xyz)
MEMWAL_ACCOUNT_ID="YOUR_MEMWAL_ACCOUNT_OBJECT_ID"

# Ed25519 private key in hex (delegate key, NOT your main wallet key)
MEMWAL_PRIVATE_KEY="YOUR_ED25519_PRIVATE_KEY_HEX"

# Walrus Memory relayer URL (Mainnet)
MEMWAL_SERVER_URL="https://relayer.memory.walrus.xyz"

# Namespace for isolating app memories
MEMWAL_NAMESPACE="ai-match-predictor"

# ===== ON-CHAIN PREDICTION CONTRACT (Sui Mainnet) =====
# Deploy the contract first:
#   sui client publish --gas-budget 50000000 contracts/prediction
# Then copy the published package ID and PredictionMarket object ID below.

# Published package ID from the deploy output
VITE_SUI_PACKAGE_ID="YOUR_PUBLISHED_PACKAGE_ID"

# Created PredictionMarket shared object ID from the deploy output
VITE_SUI_MARKET_ID="YOUR_MARKET_OBJECT_ID"
VITE_SUI_MARKET_INITIAL_SHARED_VERSION=123456

# ===== VERCEL KV (Upstash Redis) =====
# Required for data persistence on Vercel.
# Auto-injected when you add Vercel KV via the Marketplace.
# Get these from your Upstash console or Vercel KV dashboard.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
